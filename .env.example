# --- API ---
DATABASE_URL=postgres://dev:dev@localhost:5432/dailyalt
PORT=3000
HOST=0.0.0.0
# Secret for the /api/admin/* routes. In production this must be set and ≥24
# chars (generate: openssl rand -hex 32) or the API refuses to boot.
ADMIN_API_KEY=change-me
# Optional admin lockdown (see .env.production.example for the full rundown):
# restrict the dashboard to a comma-separated client-IP allowlist. Empty = off.
ADMIN_ALLOWED_IPS=
# Trust X-Forwarded-* from a front proxy so the IP allowlist sees the real
# client. Only enable behind a real reverse proxy.
TRUST_PROXY=false
# Toggle the background ingestion cron (set to false to run the API without fetching).
INGEST_ENABLED=true
# Ranking gravity: lower = stickier/older content survives, higher = fresher. Default 1.6.
GRAVITY=1.6
# Minimum votes for a community source to auto-approve. Real threshold is
# max(this floor, a majority of all known users). Admins can override.
SOURCE_APPROVE_VOTES=10
# CORS origin for read endpoints. "*" is fine since there is no auth/cookies.
CORS_ORIGIN=*
# Contact URL advertised in the ingestion User-Agent so publishers can reach you.
INGEST_CONTACT_URL=https://github.com/yourname/daily-dev-alt

# --- Extension (Vite, must be prefixed with VITE_) ---
VITE_API_BASE_URL=http://localhost:3000
