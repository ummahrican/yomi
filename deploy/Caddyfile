# Caddy auto-provisions and renews a Let's Encrypt cert for $API_DOMAIN and
# reverse-proxies HTTPS traffic to the API container. Caddy's ACME registration
# email defaults to the host; set one explicitly if you want renewal notices.
{$API_DOMAIN} {
	encode zstd gzip
	reverse_proxy api:3000

	# Basic hardening headers (the API serves JSON + the admin HTML page).
	header {
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	log {
		output stdout
		format console
	}
}
