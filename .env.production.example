# Production env for docker-compose.prod.yml. Copy to `.env.production` and fill
# in. Keep `.env.production` OUT of git (it is gitignored alongside .env).
#
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# --- Domain / TLS ---
# The hostname whose A record points at this VPS. Caddy gets a cert for it.
API_DOMAIN=api.yomi.fyi

# --- Postgres (internal to the compose network; never published) ---
POSTGRES_USER=yomi
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=yomi

# --- API ---
# REQUIRED in production — the API refuses to boot if this is still "change-me"
# OR shorter than 24 characters. This single secret gates the whole admin
# dashboard (sponsors + source moderation), so make it strong and keep it secret.
# Generate: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_STRONG_ADMIN_KEY

# Optional admin lockdown — restrict the dashboard to specific client IPs.
# Empty (default) = anyone with the key above can reach it. Set to a
# comma-separated allowlist (e.g. your home/office IP) to be the only one in.
# Behind a reverse proxy this REQUIRES TRUST_PROXY=true (below), otherwise every
# request looks like it comes from the proxy and you lock yourself out.
ADMIN_ALLOWED_IPS=
# Trust X-Forwarded-* from the front proxy so the API sees the real client IP.
# Caddy/Traefik terminate TLS in front of this container, so set this to true in
# that setup. Leave false if the API is directly reachable (IPs can be spoofed).
TRUST_PROXY=true

# "*" is acceptable: the read API has no cookies/credentials and the extension's
# Origin is chrome-extension://<id>, which a domain allowlist cannot match.
CORS_ORIGIN=*
GRAVITY=1.6
SOURCE_APPROVE_VOTES=10
INGEST_ENABLED=true
INGEST_CONTACT_URL=https://github.com/ummahrican/yomi
