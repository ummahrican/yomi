{
  "name": "@daily-alt/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate-and-start": "tsx src/db/migrate.ts && tsx src/ingest/sources.seed.ts && tsx src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/ingest/sources.seed.ts",
    "ingest:once": "tsx src/ingest/runOnce.ts"
  },
  "dependencies": {
    "@daily-alt/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "cheerio": "^1.0.0",
    "croner": "^8.1.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "p-limit": "^6.1.0",
    "pg": "^8.13.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
